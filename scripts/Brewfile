tap "supabase/tap"

# --- Dev essentials (always install) -----------------------------------------
brew "awscli"               # AWS CLI
brew "cloudflared"          # Cloudflare Tunnel client
brew "ffmpeg"               # Audio/video codec processing
brew "gh"                   # GitHub CLI
brew "git"
brew "git-filter-repo"      # Repo history rewriting
brew "git-lfs"              # Large file storage
brew "glab"                 # GitLab CLI
brew "mas"                  # Mac App Store CLI
brew "mysql-client"
brew "openssh"
brew "pipx"                 # Isolated Python package execution
brew "poppler"              # PDF rendering library
brew "rsync"                # GNU rsync — macOS system one is too old (no --info=progress2)
brew "yarn"
brew "supabase/tap/supabase"

# --- Runtimes ----------------------------------------------------------------
brew "node@24"              # Active LTS
brew "python@3.13"          # Latest stable
brew "python@3.12"          # Keep for broader compatibility with older packages

# --- GUI apps (casks) --------------------------------------------------------
# NOTE: docker-desktop requires sudo to pre-create /usr/local/cli-plugins
# (see restore.sh — it does this for you). mysqlworkbench has NO dash (the
# dashed name doesn't exist). github cask = GitHub Desktop.
cask "cursor"
cask "dbeaver-community"
cask "docker-desktop"
cask "firefox"
cask "github"               # GitHub Desktop
cask "mysqlworkbench"
cask "raycast"
cask "rectangle"
cask "sublime-text"
cask "visual-studio-code"

